{
  "manifest_version": 3,
  "name": "Notion Formula Copier",
  "version": "1.0.0",
  "description": "One-click convert $...$ and $$...$$ to Notion equation blocks.",
  "permissions": ["contextMenus"],
  "host_permissions": ["*://*.notion.so/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Notion Formula Copier"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.notion.so/*"],
      "js": ["notion-convert.js"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
